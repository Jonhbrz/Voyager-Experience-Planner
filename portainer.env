# Variables del stack vep-portainer.
# Pegar en Portainer → Stacks → Add stack → Environment variables (o "Load variables from .env file").
#
# IMPORTANTE — diferencia entre las dos rutas del proyecto:
#   PROJECT_BUILD: ruta DENTRO del contenedor de Portainer (de ahí lee el build context).
#                  Requiere arrancar Portainer con -v c:/Users/jonat/PRW-VEP:/projects/vep
#   PROJECT_MOUNT: ruta en el HOST del daemon (Docker Desktop). Se usa en los bind mounts
#                  de los contenedores hijos. Docker Desktop traduce la ruta de Windows.
PROJECT_BUILD=/projects/vep
PROJECT_MOUNT=c:/Users/jonat/PRW-VEP

# Puertos del host (elegidos para no chocar con vep-dev (5434/8002/5173) ni vep-prod (5433/8001/5174)).
DB_HOST_PORT=5435
BACKEND_HOST_PORT=8003
FRONTEND_HOST_PORT=5175

APP_ENV=local
APP_DEBUG=true

# APP_KEY nueva, NO reutilizar la de dev/prod.
APP_KEY=base64:SRWvbV7mjv4vgA2ZqbsbWrM4ffOgFinHG8v7jdEqIG8=

# URLs alineadas con BACKEND_HOST_PORT y FRONTEND_HOST_PORT.
APP_URL=http://localhost:8003
FRONTEND_URL=http://localhost:5175
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://localhost:8003
SANCTUM_STATEFUL_DOMAINS=localhost:5175,localhost:8003

# Inyectada en el frontend en runtime de Vite. Si cambias BACKEND_HOST_PORT, cambia también esto.
VITE_API_BASE_URL=http://localhost:8003/api

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=app_portainer
DB_USERNAME=postgres
DB_PASSWORD=postgres
